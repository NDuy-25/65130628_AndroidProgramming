<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_light"
    android:gravity="center_horizontal">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgSinhVien"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/d9a7d38f_ba9f_4481_a7fb_1b37f1186402_removebg_preview_4"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:padding="4dp"
        app:strokeColor="@color/primary"
        app:strokeWidth="2dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.LargeComponent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thông tin sinh viên"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/btn_4"
        android:layout_marginBottom="32dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ và Tên"
                android:textColor="@color/text_sub"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvHoTen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyễn Đức Duy"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã số sinh viên"
                android:textColor="@color/text_sub"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvMaSo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65130628"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lớp học"
                android:textColor="@color/text_sub"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvLop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65.CNTT-2"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ"
                android:textColor="@color/text_sub"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvDiaChi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nha Trang, Khánh Hòa"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnQuayLai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quay lại Trang chủ"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:textColor="@color/btn_back" />

</LinearLayout>