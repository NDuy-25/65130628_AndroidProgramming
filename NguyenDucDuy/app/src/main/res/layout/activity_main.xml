<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/bg_light">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BÀI THI GIỮA KỲ"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sinh viên: Nguyễn Đức Duy"
        android:textSize="16sp"
        android:textColor="@color/text_sub"
        android:layout_marginBottom="40dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChucNang1"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Chức năng 1: Đổi tiền"
        app:cornerRadius="12dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/btn_1"
        android:textSize="16sp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChucNang2"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Chức năng 2: Ca khúc cách mạng"
        app:cornerRadius="12dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/btn_2"
        android:textSize="16sp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChucNang3"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Chức năng 3: Danh nhân lịch sử"
        app:cornerRadius="12dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/btn_3"
        android:textSize="16sp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChucNang4"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Chức năng 4: Thông tin cá nhân"
        app:cornerRadius="12dp"
        android:backgroundTint="@color/btn_4"
        android:textSize="16sp"/>

</LinearLayout>