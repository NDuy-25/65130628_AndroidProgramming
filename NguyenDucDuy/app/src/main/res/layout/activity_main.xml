<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:id="@+id/main">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BÀI THI GIỮA KỲ"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnChucNang1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 1: Đổi tiền"/>

    <Button
        android:id="@+id/btnChucNang2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 2: Ca khúc cách mạng"/>

    <Button
        android:id="@+id/btnChucNang3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 3: Danh nhân lịch sử"/>

    <Button
        android:id="@+id/btnChucNang4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chức năng 4: Thông tin cá nhân"/>

</LinearLayout>